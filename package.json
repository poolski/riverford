    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  }
}
